<h1 class="mb-6 text-2xl font-bold tracking-tight text-gray-900">Dashboard</h1>

<h2 class="mb-3 text-lg font-semibold text-gray-900">Goals by status</h2>
<table class="mb-8 w-full text-sm">
  <tbody>
    <% @goals_by_status.each do |status, count| %>
      <tr class="border-b border-gray-100">
        <td class="py-2 text-gray-700"><%= status %></td>
        <td class="py-2 text-right font-medium"><%= count %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back to goals", goals_path, class: "btn-ghost" %>
