<h1 class="mb-6 text-2xl font-bold tracking-tight text-gray-900">Edit goal</h1>

<%= render "form", goal: @goal %>

<%= button_to "Delete goal", goal_path(@goal), method: :delete, class: "btn-ghost mt-4",
              data: { turbo_confirm: "Are you sure?" } %>
<%= link_to "Back to goals", goals_path, class: "btn-ghost mt-6" %>
