<%# Showcase strip: this repo is built BY an AI factory, and this strip
    shows that factory's own pipeline. Purely informational — nothing here
    affects bookmarks. Steps are hardcoded: the pipeline is fixed by
    .claude/rules/factory.md, so a config layer would be dead weight. %>
<% steps = [
     ["refine",    "rough idea → test-verifiable ticket"],
     ["plan",      "research fan-out → one step per criterion"],
     ["implement", "red → green → commit, per criterion"],
     ["review",    "reviewer agents + browser drive"],
     ["merge",     "human verdict → PR → main"],
   ] %>

<div class="pipeline">
  <% steps.each_with_index do |(name, detail), i| %>
    <%# Connector line BETWEEN nodes (not before the first). %>
    <% if i.positive? %><span class="connector" aria-hidden="true"></span><% end %>
    <div class="step">
      <span class="step-dot"><%= i + 1 %></span>
      <span class="step-label"><%= name %></span>
    </div>
  <% end %>
</div>
