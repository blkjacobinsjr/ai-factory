<%# The homepage: every saved bookmark as a card (see .card in
    app/assets/tailwind/application.css). @bookmarks comes from
    BookmarksController#index, newest first. %>
<%# The factory's own process, animated — see _pipeline.html.erb. %>
<%= render "pipeline" %>

<div class="mb-8 flex items-center justify-between">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900">Bookmarks</h1>
  <%# Without this link the add-bookmark form exists but nothing points to it. %>
  <%= link_to "New bookmark", new_bookmark_path, class: "btn" %>
</div>

<ul class="space-y-3">
  <% @bookmarks.each do |bookmark| %>
    <%# One card per bookmark: title link on the left, actions on the right.
        The test suite pins this structure — actions must stay INSIDE .card. %>
    <li class="card">
      <%# link_to escapes the title, so a title like "<script>" renders as
          harmless text instead of running as code. %>
      <%= link_to bookmark.title, bookmark.url,
                  class: "font-medium text-gray-900 hover:underline" %>
      <div class="flex items-center gap-1">
        <%= link_to "Edit", edit_bookmark_path(bookmark), class: "btn-ghost" %>
        <%# button_to sends a real DELETE request (a plain link can't);
            the confirm dialog is the only guard against accidental loss. %>
        <%= button_to "Delete", bookmark_path(bookmark), method: :delete,
                      class: "btn-ghost",
                      data: { turbo_confirm: "Are you sure?" } %>
      </div>
    </li>
  <% end %>
</ul>
